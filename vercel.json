{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build && cp app.apk dist/",
  "outputDirectory": "dist",
  "framework": "vite",
  "functions": {
    "api/proxy.js": {
      "maxDuration": 60
    }
  },
  "headers": [
    {
      "source": "/app.apk",
      "headers": [
        { "key": "Content-Type", "value": "application/vnd.android.package-archive" },
        { "key": "Content-Disposition", "value": "attachment; filename=\"app.apk\"" }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/latest.exe",
      "destination": "https://github.com/kxng1080xx/ZIPTVPRO/releases/latest/download/latest.exe",
      "permanent": false
    }
  ],
  "rewrites": [
    { "source": "/((?!api/|app.apk|latest.exe|version.json).*)", "destination": "/index.html" }
  ]
}
