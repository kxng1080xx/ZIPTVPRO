{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build && cp app.apk dist/ && cp cast.apk dist/",
  "outputDirectory": "dist",
  "framework": "vite",
  "functions": {
    "api/proxy.js": {
      "maxDuration": 60
    },
    "api/admin.js": {
      "maxDuration": 15
    },
    "api/device.js": {
      "maxDuration": 15
    }
  },
  "headers": [
    {
      "source": "/app.apk",
      "headers": [
        { "key": "Content-Type", "value": "application/vnd.android.package-archive" },
        { "key": "Content-Disposition", "value": "attachment; filename=\"app.apk\"" }
      ]
    },
    {
      "source": "/cast.apk",
      "headers": [
        { "key": "Content-Type", "value": "application/vnd.android.package-archive" },
        { "key": "Content-Disposition", "value": "attachment; filename=\"cast.apk\"" }
      ]
    },
    {
      "source": "/version.json",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Cache-Control", "value": "no-store" }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/latest.exe",
      "destination": "https://github.com/kxng1080xx/ZIPTVPRO/releases/latest/download/latest.exe",
      "permanent": false
    }
  ],
  "rewrites": [
    { "source": "/connect", "destination": "/connect.html" },
    { "source": "/((?!api/|app.apk|cast.apk|latest.exe|version.json|connect).*)", "destination": "/index.html" }
  ]
}
