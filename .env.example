# ZIPTV Pro 5.0 — server-side env vars (set these in Vercel → Project → Settings → Environment Variables)
# These are SERVER ONLY. Never commit real values; never ship them to the client.

# Supabase project URL, e.g. https://jnocgdemunelygygnozw.supabase.co
SUPABASE_URL=

# Supabase SERVICE ROLE key (Settings → API → service_role). Bypasses RLS. Keep secret.
SUPABASE_SERVICE_ROLE_KEY=

# Password you type on the /connect admin dashboard.
ADMIN_PASSWORD=

# Long random string used to sign admin session tokens (e.g. `openssl rand -hex 32`).
ADMIN_SECRET=

# Existing — GitHub token for electron-builder publish (already in your local .env).
# GH_TOKEN=
