{
  "name": "iptv-player-zero",
  "productName": "ZIPTV Pro",
  "version": "3.21.1",
  "description": "Premium IPTV Player - ZIPTV Pro",
  "main": "main.electron.cjs",
  "type": "module",
  "scripts": {
    "dev:server": "nodemon server/index.js",
    "dev:client": "vite",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "build": "node scripts/gen-version.mjs && vite build",
    "bump": "node scripts/bump-version.mjs",
    "preview": "vite preview",
    "start": "node server/index.js",
    "electron:start": "electron .",
    "electron:dist": "npm run bump && npm run build && electron-builder",
    "apk": "npm run bump && npm run build && npx cap sync android && cd android && gradlew.bat assembleDebug && cd .. && copy /Y android\\app\\build\\outputs\\apk\\debug\\app-debug.apk app.apk && copy /Y app.apk ZIPTV-Pro.apk && echo APK ready: app.apk + ZIPTV-Pro.apk"
  },
  "dependencies": {
    "@capacitor/app": "^8.1.0",
    "@capacitor/screen-orientation": "^8.0.1",
    "chromecasts": "^1.10.2",
    "cors": "^2.8.5",
    "dexie": "^4.4.3",
    "dlnacasts": "^0.1.0",
    "express": "^4.21.2",
    "hls.js": "^1.5.15",
    "mpegts.js": "^1.8.0"
  },
  "devDependencies": {
    "@capacitor/android": "^8.4.0",
    "@capacitor/cli": "^8.4.0",
    "@capacitor/core": "^8.4.0",
    "concurrently": "^9.1.2",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.3",
    "nodemon": "^3.1.9",
    "vite": "^6.2.0"
  },
  "build": {
    "appId": "com.iptv.player.zero",
    "productName": "ZIPTV Pro",
    "files": [
      "dist/**/*",
      "server/**/*",
      "electron/**/*",
      "main.electron.cjs",
      "package.json"
    ],
    "win": {
      "target": "nsis"
    },
    "directories": {
      "output": "dist-electron"
    },
    "asar": true
  }
}
