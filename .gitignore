# Dependencies
node_modules/
.claude
.vscode

# Production builds
dist/
dist-electron/
*.apk
*.zip
# …but the published download must be committed so Vercel can serve it.
!app.apk
!cast.apk
latest.exe

# Secrets — GitHub token for `npm run release`, etc. Never commit.
.env
.env.local

# Local server database and Xtream credentials cache
server/data/
credentials.json
playlist_cache.json
epg_cache.json

# Android Studio and Gradle settings/caches
.gradle/
.idea/
build/
local.properties
capture/
android/.gradle/
android/app/build/
android/local.properties
android/.idea/

# OS Files
.DS_Store
Thumbs.db

# Generated at build time
public/version.json

# Local binaries for packaging
extraResources/

# Custom Electron codec build — huge upstream checkout + built dist are local-only.
# (The guide, scripts, and ported patches under electron-codecs/ ARE committed.)
electron-codecs/upstream/
electron-codecs/dist/
electron-src/

